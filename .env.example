# Contact form — Resend (https://resend.com/api-keys). Required in production,
# otherwise /api/contact returns 503 and the form shows a fallback error.
RESEND_API_KEY=

# Where leads are delivered. Defaults to contact@studio-albatre.fr (src/lib/site.ts).
CONTACT_TO_EMAIL=

# Sender address. Defaults to onboarding@resend.dev (works before the domain
# studio-albatre.fr is verified in Resend; switch to e.g. contact@studio-albatre.fr after).
CONTACT_FROM_EMAIL=
